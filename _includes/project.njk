---
layout: base.njk
---

<div class="page-container">
  <a href="/projects" class="back-link">← Back to Projects</a>

  <article>
    <header class="page-header">
      <h1>{{ title }}</h1>
      {% if liveUrl or github %}
      <div class="project-links">
        {% if liveUrl %}<a href="{{ liveUrl }}" target="_blank" rel="noopener" class="project-link">Live site →</a>{% endif %}
        {% if github %}<a href="{{ github }}" target="_blank" rel="noopener" class="project-link">GitHub →</a>{% endif %}
      </div>
      {% endif %}
    </header>

    <div class="post-content">
      {{ content | safe }}
    </div>
  </article>
</div>
